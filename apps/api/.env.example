# Postgres connection (Railway provides this in production)
DATABASE_URL="postgresql://user:pass@localhost:5432/broccoli"

# better-auth — generate a long random secret (e.g. `openssl rand -base64 32`)
BETTER_AUTH_SECRET="replace-me-with-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3000"

# Shared secret for internal scheduler -> api tRPC calls.
# Must match the value configured in broccoli-scheduler.
INTERNAL_SERVICE_TOKEN="replace-me-shared-with-broccoli-scheduler"

# UploadThing — receipt image storage. Copy the app token from the UploadThing
# dashboard (Legacy: keys → v7 token). Powers /api/uploadthing.
UPLOADTHING_TOKEN="replace-me-with-uploadthing-app-token"

# broccoli-model — the receipt parser (FastAPI). receipt.create POSTs the image
# URL + ItemType catalog to /ocr. URL is the service base (no trailing /ocr);
# the API key must match broccoli-model's API_KEY.
BROCCOLI_MODEL_URL="http://localhost:8000"
BROCCOLI_MODEL_API_KEY="replace-me-shared-with-broccoli-model"

PORT=3000
