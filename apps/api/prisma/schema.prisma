// broccoli-api owns this schema and all migrations (see PRD §4).
// broccoli-scheduler reads/writes the same Postgres but never defines or runs
// migrations — it goes through broccoli-api's internal tRPC procedures instead.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth models (better-auth). Regenerate with `npx @better-auth/cli generate`
// if you change the auth config.
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  receipts      Receipt[]
  items         Item[]

  pushTokens           PushToken[]
  notificationSettings NotificationSettings?

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ---------------------------------------------------------------------------
// App models (Phase 1 — capture → extract → review).
// ---------------------------------------------------------------------------

// A captured grocery receipt. Created as PROCESSING when the photo is uploaded;
// broccoli-model parses it asynchronously, then the user reviews + saves.
model Receipt {
  id            String        @id @default(cuid())
  userId        String
  imageUrl      String // fetchable URL (UploadThing); broccoli-model reads this
  imageKey      String? // UploadThing key, for later deletion
  status        ReceiptStatus @default(PROCESSING)
  storeName     String?
  purchasedAt   DateTime?
  total         Float? // receipt total (spend tracking, PRD §4)
  rawExtraction Json? // raw broccoli-model output, for debugging + feedback
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         Item[]

  @@index([userId])
  @@map("receipt")
}

// A single line item from a receipt. `category` holds the snapped ItemType name
// (the parser maps to the catalog); the explicit ItemType relation + expiration
// fields arrive in Phase 3.
//
// Lifecycle (Phase 2): items start ACTIVE (they're your inventory once the
// receipt is SAVED) and get resolved to EATEN or TOSSED by the daily check-in
// swipe. Those outcomes are the waste metric's raw data (PRD §1). Phase 3 adds
// scheduler-driven expiry transitions.
model Item {
  id         String     @id @default(cuid())
  receiptId  String
  userId     String
  name       String
  price      Float? // line price (spend tracking, PRD §4)
  quantity   Int        @default(1)
  unit       String     @default("")
  category   String? // snapped ItemType name, or null/Unknown
  status     ItemStatus @default(ACTIVE)
  resolvedAt DateTime? // when the user swiped it eaten/tossed; null while ACTIVE

  // Expiration advice (Phase 3). Set at save time from the ItemType's
  // per-location shelf life; `expirationSource` says where the estimate came
  // from so the app can always show a reason (PRD Pillar 3). EXPIRED items
  // keep their expiresAt; resolvedAt stays null until the user acts.
  itemTypeId       String?
  storageLocation  StorageLocation?
  expiresAt        DateTime?
  expirationSource ExpirationSource?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  receipt   Receipt   @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemType  ItemType? @relation(fields: [itemTypeId], references: [id], onDelete: SetNull)

  @@index([receiptId])
  @@index([userId, status]) // inventory + check-in deck query by owner and status
  @@index([status, expiresAt]) // scheduler sweep: ACTIVE items past their date
  @@map("item")
}

// Shelf-life catalog seeded from USDA FoodKeeper (CC0). The parser categorizes
// items against `name`; Phase 3 derives expiration advice from the shelf-life
// data. Location-agnostic for now — `raw` keeps the full FoodKeeper record so
// Phase 3 can expand to pantry/fridge/freezer ranges without re-running the ETL.
model ItemType {
  id                       String @id @default(cuid())
  name                     String @unique
  category                 String
  suggestedLifeSpanSeconds Int
  storageAdvice            String @default("")
  source                   String @default("FoodKeeper")
  raw                      Json?

  // Per-location shelf life (Phase 3), derived from the raw FoodKeeper record
  // by the seed. Null = FoodKeeper has no usable timeframe for that location.
  pantrySeconds  Int?
  fridgeSeconds  Int?
  freezerSeconds Int?
  pantryTip      String @default("")
  fridgeTip      String @default("")
  freezerTip     String @default("")

  items Item[]

  @@map("item_type")
}

// ---------------------------------------------------------------------------
// Push nudges (Phase 4).
// ---------------------------------------------------------------------------

// One Expo push token per installed device. Pruned automatically when Expo
// reports DeviceNotRegistered during a send.
model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique // ExponentPushToken[...]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_token")
}

// Per-user nudge preferences (PRD Pillar 4: welcome, not annoying). Quiet
// hours are local hours in `timezone` and may wrap midnight (21 → 8).
// `lastNudgeAt` enforces at most one grouped nudge per local day.
model NotificationSettings {
  id              String    @id @default(cuid())
  userId          String    @unique
  nudgesEnabled   Boolean   @default(true)
  quietHoursStart Int       @default(21) // inclusive, 0-23
  quietHoursEnd   Int       @default(8) // exclusive, 0-23
  timezone        String    @default("UTC") // IANA, reported by the device
  lastNudgeAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_settings")
}

enum ReceiptStatus {
  PROCESSING
  READY
  SAVED
  ERROR
}

// Item lifecycle. EATEN and TOSSED come from the daily check-in; EXPIRED is
// applied by the scheduler when an ACTIVE item passes its expiresAt (the user
// still resolves it to EATEN/TOSSED afterwards — expiry isn't an outcome).
enum ItemStatus {
  ACTIVE
  EATEN
  TOSSED
  EXPIRED
}

// Where the item is stored — picks which FoodKeeper timeframe applies.
enum StorageLocation {
  PANTRY
  FRIDGE
  FREEZER
}

// Where an item's expiration estimate came from (PRD Pillar 3: every estimate
// shows its reason). USER always wins over recomputation.
enum ExpirationSource {
  FOODKEEPER
  LLM
  USER
}
