{
  "name": "broccoli",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "description": "Broccoli monorepo — mobile app + API. Cut food waste; track grocery spend.",
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter broccoli-api dev",
    "dev:mobile": "pnpm --filter broccoli-mobile start",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  }
}
